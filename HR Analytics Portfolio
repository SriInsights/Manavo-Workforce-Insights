        "def build_alumni_position_history(emp):\n",
        "    hire = pd.Timestamp(emp[\"hire_date\"])\n",
        "    n_promo = emp[\"n_promotions\"]\n",
        "    total_span_days = (pd.Timestamp(emp[\"termination_date\"]) - hire).days   # <- CHANGE for alumni\n",
        "    segment_length = total_span_days / (n_promo + 1)\n",
        "\n",
        "    rows = []\n",
        "    for i in range(n_promo + 1):\n",
        "        start = hire + pd.Timedelta(days=segment_length * i)\n",
        "        end = pd.Timestamp(emp[\"termination_date\"]) if i == n_promo else hire + pd.Timedelta(days=segment_length * (i + 1))  # <- CHANGE for alumni\n",
        "        level = min(emp[\"starting_level\"] + i, 7)\n",
        "        rows.append({\n",
        "            \"employee_id\": emp[\"employee_id\"],\n",
        "            \"effective_start_date\": start,\n",
        "            \"effective_end_date\": end,\n",
        "            \"job_level\": level\n",
        "        })\n",
        "    return rows\n",
        "\n"
      ],
      "metadata": {
        "id": "hi6TR7Npiu2k"
      },

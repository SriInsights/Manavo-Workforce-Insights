    {
      "cell_type": "code",
      "source": [
        "def assign_termination_reason(category):\n",
        "    if category == \"never_started\":\n",
        "        return random.choice(never_started_reasons)\n",
        "\n",
        "    # small independent chance of layoff, regardless of category\n",
        "    if random.random() < 0.08:\n",
        "        return \"Layoff/Restructuring\"\n",
        "\n",
        "    voluntary_rate = voluntary_rate_by_category[category]\n",
        "    if random.random() < voluntary_rate:\n",
        "        return random.choice(voluntary_reasons)\n",
        "    else:\n",
        "        return random.choice([r for r in involuntary_reasons if r != \"Layoff/Restructuring\"])"
      ],
      "metadata": {
        "id": "8R8KnsNFkEwW"
      },
      "execution_count": 74,
      "outputs": []

        "        rows.append({\n",
        "            \"employee_id\": emp[\"employee_id\"],\n",
        "            \"effective_start_date\": start,\n",
        "            \"effective_end_date\": end,\n",
        "            \"job_level\": level\n",
        "        })\n",
